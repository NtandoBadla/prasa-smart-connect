# -- Server --------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:8080

# -- Vite frontend -> backend URL (must start with VITE_) ---------------------
VITE_API_URL=http://localhost:3001

# -- Admin credentials --------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASS=prasa2025
# Email that receives safety incident notifications
ADMIN_EMAIL=admin@yourdomain.com
# Secret used to sign admin tokens -- set a long random string in production
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# -- Supabase -----------------------------------------------------------------
# Get these from: https://supabase.com -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# -- SerpAPI ------------------------------------------------------------------
# Get your key from: https://serpapi.com/manage-api-key
SERPAPI_KEY=your-serpapi-key

# -- EmailJS ------------------------------------------------------------------
# Get these from: https://www.emailjs.com -> Account -> API Keys & Services
EMAILJS_SERVICE_ID=your-service-id
EMAILJS_TEMPLATE_ID=your-template-id
# Optional: separate template for safety incident admin alerts
EMAILJS_SAFETY_TEMPLATE_ID=your-safety-template-id
EMAILJS_PUBLIC_KEY=your-public-key
EMAILJS_PRIVATE_KEY=your-private-key

# -- TextBee (SMS notifications) ----------------------------------------------
# Sign up at: https://textbee.dev -> Dashboard -> API Keys
# Install the TextBee app on an Android device, register it, then copy the device ID
TEXTBEE_API_KEY=your-textbee-api-key
TEXTBEE_DEVICE_ID=your-device-id

# -- Stripe ------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_ / pk_test_) for development
STRIPE_SECRET_KEY=sk_test_your-secret-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# -- OpenAI (optional -- chatbot falls back to rule-based if not set) ---------
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key

# -- Hugging Face (optional -- sentiment analysis uses VADER fallback if not set)
# Get your key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-token
VITE_HF_API_TOKEN=your-huggingface-token

VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
