{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "types": ["node"],
    "outDir": "dist-server",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["server/**/*", "scripts/**/*", "src/data/**/*", "netlify/**/*"],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
